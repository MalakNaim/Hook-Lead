# ── Database ──────────────────────────────────────────────────────────────────
ConnectionStrings__DefaultConnection=Server=localhost,1433;Database=HookLeads;User Id=sa;Password=YourPassword123!;TrustServerCertificate=True

# ── JWT ───────────────────────────────────────────────────────────────────────
Jwt__Secret=your-256-bit-secret-key-here
Jwt__Issuer=HookLeads
Jwt__Audience=HookLeads
Jwt__ExpiryMinutes=60
Jwt__RefreshTokenExpiryDays=30

# ── Claude AI ─────────────────────────────────────────────────────────────────
Claude__ApiKey=sk-ant-...

# ── Gmail OAuth ───────────────────────────────────────────────────────────────
Gmail__ClientId=
Gmail__ClientSecret=

# ── Hangfire ──────────────────────────────────────────────────────────────────
Hangfire__DashboardPath=/hangfire

# ── Logging ───────────────────────────────────────────────────────────────────
Serilog__MinimumLevel=Information
